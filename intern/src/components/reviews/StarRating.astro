---
// src/components/reviews/StarRating.astro
interface Props {
  rating: number; // 1-5, rounds to nearest whole star for display
  size?: "sm" | "md" | "lg";
  showNumber?: boolean;
  class?: string;
}

const { rating, size = "md", showNumber = false } = Astro.props;
const rounded = Math.round(Math.min(5, Math.max(0, rating)));

const sizeClasses = {
  sm: "w-3.5 h-3.5",
  md: "w-4.5 h-4.5",
  lg: "w-6 h-6",
};
---

<div class={`flex items-center gap-1 ${Astro.props.class || ""}`} role="img" aria-label={`${rating.toFixed(1)} out of 5 stars`}>
  <div class="flex" aria-hidden="true">
    {
      Array.from({ length: 5 }).map((_, i) => (
        <svg
          class={`${sizeClasses[size]} ${i < rounded ? "text-[#F0A93B]" : "text-gray-300 dark:text-gray-600"}`}
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.958a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.368 2.446a1 1 0 00-.363 1.118l1.287 3.957c.3.922-.755 1.688-1.538 1.118l-3.367-2.446a1 1 0 00-1.176 0l-3.367 2.446c-.783.57-1.838-.196-1.538-1.118l1.287-3.957a1 1 0 00-.363-1.118L2.063 9.385c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.951-.69l1.285-3.958z" />
        </svg>
      ))
    }
  </div>
  {showNumber && (
    <span class="text-sm font-semibold text-gray-700 dark:text-gray-200">
      {rating.toFixed(1)}
    </span>
  )}
</div>