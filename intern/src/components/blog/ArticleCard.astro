---
// src/components/blog/ArticleCard.astro
import type { TArticle } from "../../types/blog";
import StrapiImage from "../StrapiImage.astro";

type Props = { article: TArticle };

const { article } = Astro.props;
---

<a
  href={`/blog/${article.slug}`}
  class="block rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-md transition"
>
  {
    article.featuredImage?.url && (
      <StrapiImage
        src={article.featuredImage.url}
        alt={article.featuredImage.alternativeText || article.title}
        width={400}
        height={240}
        class="w-full h-48 object-cover"
      />
    )
  }
  <div class="p-5">
    <h3 class="font-bold text-gray-900 mb-1">{article.title}</h3>
    <p class="text-sm text-gray-600 mb-3">{article.description}</p>
    <div class="flex items-center justify-between">
      {
        article.author?.fullName && (
          <p class="text-xs text-gray-400">By {article.author.fullName}</p>
        )
      }
      {
        article.contentTags?.length > 0 && (
          <div class="flex gap-2">
            {article.contentTags.map((tag) => (
              <span class="text-xs bg-green-50 text-green-700 px-2 py-1 rounded-full">
                {tag.title}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</a>