---
// src/components/blog/ArticleCard.astro
import type { TArticle } from "../../types/blog";
import StrapiImage from "../StrapiImage.astro";

type Props = { article: TArticle };

const { article } = Astro.props;
---

<a
  href={`/blog/${article.slug}`}
  class="block rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 overflow-hidden shadow-sm hover:shadow-md transition"
>
  {
    article.featuredImage?.url && (
      <StrapiImage
        src={article.featuredImage.url}
        alt={article.featuredImage.alternativeText || article.title}
        width={400}
        height={240}
        class="w-full h-48 object-cover"
      />
    )
  }
  
  <div class="p-5">
    <h3 class="font-bold text-gray-900 dark:text-white text-lg mb-1">
      {article.title}
    </h3>
    <p class="text-sm text-gray-600 dark:text-gray-300 mb-4 line-clamp-2">
      {article.description}
    </p>
    
    <div class="flex items-center justify-between pt-2 border-t border-gray-100 dark:border-gray-700/50">
      {
        article.author?.fullName && (
          <p class="text-xs text-gray-500 dark:text-gray-400 font-medium">
            By {article.author.fullName}
          </p>
        )
      }

      {
        article.contentTags && article.contentTags.length > 0 && (
          <div class="flex gap-2">
            {article.contentTags.map((tag) => (
              <span class="text-xs bg-emerald-100 dark:bg-emerald-500/20 text-emerald-800 dark:text-emerald-300 px-2.5 py-0.5 rounded-full border border-emerald-200 dark:border-emerald-500/30">
                {tag.title}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</a>