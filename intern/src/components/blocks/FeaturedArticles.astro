---
// src/components/blocks/FeaturedArticles.astro
import type { TFeaturedArticlesBlock } from "../../types/landing";
import StrapiImage from "../StrapiImage.astro";

type Props = TFeaturedArticlesBlock;

const { articles } = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 py-14">
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
    {
      articles?.map((article) => (
        <a href={`/blog/${article.slug}`} class="block group">
          {article.featuredImage?.url && (
            <div class="rounded-lg overflow-hidden mb-4">
              <StrapiImage
                src={article.featuredImage.url}
                alt={article.featuredImage.alternativeText || article.title}
                width={400}
                height={240}
                class="w-full h-44 object-cover"
              />
            </div>
          )}
          <h3 class="font-medium text-neutral-900 mb-1 group-hover:text-neutral-600 transition-colors">
            {article.title}
          </h3>
          <p class="text-sm text-neutral-600 mb-2 leading-relaxed">{article.description}</p>
          {article.author?.fullName && (
            <p class="text-xs text-neutral-400">By {article.author.fullName}</p>
          )}
        </a>
      ))
    }
  </div>
</section>