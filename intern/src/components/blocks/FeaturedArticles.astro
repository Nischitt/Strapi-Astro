---
// src/components/blocks/FeaturedArticles.astro
import type { TFeaturedArticlesBlock } from "../../types/landing";
import StrapiImage from "../StrapiImage.astro";

type Props = TFeaturedArticlesBlock;

const { articles } = Astro.props;
---

<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      articles?.map((article) => (
        <a
          href={`/blog/${article.slug}`}
          class="block rounded-xl border border-[#14171A]/10 overflow-hidden bg-white hover:shadow-md transition"
        >
          {article.featuredImage?.url && (
            <StrapiImage
              src={article.featuredImage.url}
              alt={article.featuredImage.alternativeText || article.title}
              width={400}
              height={240}
              class="w-full h-48 object-cover"
            />
          )}
          <div class="p-5">
            <div class="w-8 h-1 bg-[#F0A93B] rounded-full mb-3" />
            <h3 class="font-display font-bold uppercase text-[#14171A] mb-1">
              {article.title}
            </h3>
            <p class="text-sm text-gray-600 mb-3">{article.description}</p>
            {article.author?.fullName && (
              <p class="text-xs text-gray-400">By {article.author.fullName}</p>
            )}
          </div>
        </a>
      ))
    }
  </div>
</section>