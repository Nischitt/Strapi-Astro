---
// src/components/blocks/SectionHeading.astro
import type { TSectionHeadingBlock } from "../../types/landing";

type Props = TSectionHeadingBlock;

const { subHeading, heading, anchorLink } = Astro.props;
---

<section
  id={anchorLink || undefined}
  class="max-w-3xl mx-auto px-6 py-16 text-center"
>
  {
    subHeading && (
      <span class="inline-block font-display uppercase tracking-[0.2em] text-xs font-bold text-[#1F6F50] border border-[#1F6F50]/30 rounded-full px-4 py-1.5 mb-4">
        {subHeading}
      </span>
    )
  }
  <h2 class="font-display text-3xl md:text-4xl font-bold uppercase text-[#14171A]">
    {heading}
  </h2>
</section>