---
// src/components/blocks/CardGrid.astro
import type { TCardGridBlock } from "../../types/landing";

type Props = TCardGridBlock;

const { cards } = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 py-14">
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-neutral-200 dark:bg-gray-600 border border-neutral-200 dark:border-gray-600">
    {
      cards?.map((card) => (
        <div class="bg-white dark:bg-gray-700 p-6">
          <h3 class="font-medium text-neutral-900 dark:text-white mb-2">
            {card.heading}
          </h3>
          <p class="text-neutral-600 dark:text-gray-300 text-sm whitespace-pre-line leading-relaxed">{card.text}</p>
        </div>
      ))
    }
  </div>
</section>