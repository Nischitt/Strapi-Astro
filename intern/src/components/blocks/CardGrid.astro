---
// src/components/blocks/CardGrid.astro
import type { TCardGridBlock } from "../../types/landing";

type Props = TCardGridBlock;

const { cards } = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 py-14">
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-neutral-200 border border-neutral-200">
    {
      cards?.map((card) => (
        <div class="bg-white p-6">
          <h3 class="font-medium text-neutral-900 mb-2">
            {card.heading}
          </h3>
          <p class="text-neutral-600 text-sm whitespace-pre-line leading-relaxed">{card.text}</p>
        </div>
      ))
    }
  </div>
</section>