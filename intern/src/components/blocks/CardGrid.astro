---
// src/components/blocks/CardGrid.astro
import type { TCardGridBlock } from "../../types/landing";

type Props = TCardGridBlock;

const { cards } = Astro.props;
---

<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {
      cards?.map((card, i) => (
        <div class="relative p-6 rounded-xl bg-white border border-[#14171A]/10">
          <span class="font-display text-4xl font-bold text-[#14171A]/10 absolute top-4 right-5">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="w-8 h-1 bg-[#F0A93B] rounded-full mb-4" />
          <h3 class="font-display text-xl font-bold uppercase text-[#14171A] mb-2">
            {card.heading}
          </h3>
          <p class="text-gray-600 text-sm whitespace-pre-line">{card.text}</p>
        </div>
      ))
    }
  </div>
</section>