---
// src/components/blocks/PersonCard.astro
import type { TPersonCardBlock } from "../../types/landing";
import StrapiImage from "../StrapiImage.astro";

type Props = TPersonCardBlock;

const { text, personName, personJob, image } = Astro.props;
---

<section class="max-w-4xl mx-auto px-6 py-16">
  <div class="flex flex-col sm:flex-row items-center gap-8 p-10 rounded-2xl bg-[#14171A] text-white">
    {
      image?.url && (
        <StrapiImage
          src={image.url}
          alt={image.alternativeText || personName}
          width={112}
          height={112}
          class="w-28 h-28 rounded-full object-cover flex-shrink-0 ring-4 ring-[#F0A93B]/30"
        />
      )
    }
    <div class="text-center sm:text-left">
      <p class="font-display text-xl italic text-gray-200 mb-4 leading-snug">
        "{text}"
      </p>
      <p class="font-bold text-white">{personName}</p>
      <p class="text-sm text-[#F0A93B]">{personJob}</p>
    </div>
  </div>
</section>