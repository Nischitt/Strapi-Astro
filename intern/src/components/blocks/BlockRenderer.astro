---
// src/components/blocks/BlockRenderer.astro
import type { TLandingPageBlock } from "../../types/landing";

import Hero from "./Hero.astro";
import SectionHeading from "./SectionHeading.astro";
import CardGrid from "./CardGrid.astro";
import ContentWithImage from "./ContentWithImage.astro";
import Markdown from "./Markdown.astro";
import PersonCard from "./PersonCard.astro";
import Faqs from "./Faqs.astro";
import Newsletter from "./Newsletter.astro";
import FeaturedArticles from "./FeaturedArticles.astro";

interface Props {
  block: TLandingPageBlock;
}

const { block } = Astro.props;

// Maps a Strapi dynamic-zone __component string to its Astro component.
const componentMap: Record<string, any> = {
  "blocks.hero": Hero,
  "blocks.section-heading": SectionHeading,
  "blocks.card-grid": CardGrid,
  "blocks.content-with-image": ContentWithImage,
  "blocks.markdown": Markdown,
  "blocks.person-card": PersonCard,
  "blocks.faqs": Faqs,
  "blocks.newsletter": Newsletter,
  "blocks.featured-articles": FeaturedArticles,
};

const Component = componentMap[block.__component];
---

{
  Component ? (
    <Component {...block} />
  ) : (
    import.meta.env.DEV && (
      <p class="text-red-500 text-sm max-w-3xl mx-auto px-6">
        No component mapped for "{block.__component}"
      </p>
    )
  )
}