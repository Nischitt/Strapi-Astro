---
// src/components/blocks/LaneDivider.astro
// The signature element: a dashed "lane line" with a mile-marker dot,
// standing in for plain whitespace between landing-page sections.
---

<div class="relative h-16 flex items-center justify-center" aria-hidden="true">
  <div class="absolute inset-y-0 left-1/2 -translate-x-1/2 border-l-2 border-dashed border-[#14171A]/15">
  </div>
  <span class="relative z-10 w-2.5 h-2.5 rounded-full bg-[#F0A93B]"></span>
</div>