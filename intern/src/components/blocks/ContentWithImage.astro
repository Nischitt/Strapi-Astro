---
// src/components/blocks/ContentWithImage.astro
import type { TContentWithImageBlock } from "../../types/landing";
import StrapiImage from "../StrapiImage.astro";

type Props = TContentWithImageBlock;

const { reversed, heading, content, link, image } = Astro.props;

const BASE_API_URL =
  import.meta.env.VITE_STRAPI_BASE_URL ?? "http://localhost:1337";

const VIDEO_EXTENSIONS = [".mp4", ".webm", ".ogg", ".mov"];

const isVideo =
  image?.mime?.startsWith("video/") ||
  VIDEO_EXTENSIONS.some((ext) => image?.url?.toLowerCase().endsWith(ext));

const mediaSrc = image?.url?.startsWith("http")
  ? image.url
  : `${BASE_API_URL}${image?.url ?? ""}`;
---

<section class="max-w-6xl mx-auto px-6 py-14">
  <div
    class={`grid md:grid-cols-2 gap-12 items-center ${
      reversed ? "md:[direction:rtl]" : ""
    }`}
  >
    <div class="md:[direction:ltr]">
      <h2 class="text-2xl md:text-3xl font-medium text-neutral-900 dark:text-white mb-4">
        {heading}
      </h2>
      <p class="text-neutral-600 dark:text-gray-300 mb-6 leading-relaxed">{content}</p>
      {
        link && (
          <a
            href={link.href}
            target={link.isExternal ? "_blank" : "_self"}
            rel={link.isExternal ? "noopener noreferrer" : undefined}
            class="inline-flex items-center px-5 py-2.5 bg-neutral-900 hover:bg-neutral-700 dark:bg-white dark:text-neutral-900 dark:hover:bg-gray-200 text-white text-sm rounded transition"
          >
            {link.label}
          </a>
        )
      }
    </div>

    {
      image?.url && (
        <div class="md:[direction:ltr] rounded-lg overflow-hidden">
          {isVideo ? (
            <video
              src={mediaSrc}
              controls
              muted
              loop
              playsinline
              class="w-full h-auto object-cover"
            >
              Your browser doesn't support embedded video.
            </video>
          ) : (
            <StrapiImage
              src={image.url}
              alt={image.alternativeText || heading}
              width={640}
              height={480}
              class="w-full h-auto object-cover"
            />
          )}
        </div>
      )
    }
  </div>
</section>