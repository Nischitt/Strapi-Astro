---
// src/components/blocks/Faqs.astro
import type { TFaqsBlock } from "../../types/landing";

type Props = TFaqsBlock;

const { faq } = Astro.props;
---

<section class="max-w-2xl mx-auto px-6 py-14">
  <div class="divide-y divide-neutral-200 border-t border-b border-neutral-200">
    {
      faq?.map((item) => (
        <details class="group py-4">
          <summary class="cursor-pointer font-medium text-neutral-900 list-none flex justify-between items-center gap-4">
            {item.heading}
            <span class="text-neutral-400 group-open:rotate-45 transition-transform">
              +
            </span>
          </summary>
          <p class="mt-3 text-neutral-600 text-sm leading-relaxed">{item.text}</p>
        </details>
      ))
    }
  </div>
</section>