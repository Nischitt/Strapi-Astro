---
// src/components/blocks/Faqs.astro
import type { TFaqsBlock } from "../../types/landing";

type Props = TFaqsBlock;

const { faq } = Astro.props;
---

<section class="max-w-3xl mx-auto px-6 py-16">
  <div class="space-y-3">
    {
      faq?.map((item) => (
        <details class="group p-5 rounded-lg border border-[#14171A]/10 open:border-[#1F6F50]/40 transition-colors">
          <summary class="cursor-pointer font-display font-bold uppercase tracking-wide text-[#14171A] list-none flex justify-between items-center">
            {item.heading}
            <span class="text-[#F0A93B] text-xl group-open:rotate-45 transition-transform">
              +
            </span>
          </summary>
          <p class="mt-3 text-gray-600 text-sm leading-relaxed">{item.text}</p>
        </details>
      ))
    }
  </div>
</section>