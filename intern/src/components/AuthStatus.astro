---
interface Props {
  user: {
    id: number;
    username: string;
    email: string;
  } | null;
}

const { user } = Astro.props;
---

{
  user ? (
    <div class="relative user-menu">
      {/* User Button */}
      <button
        id="user-menu-btn"
        class="flex items-center gap-3 rounded-lg border border-gray-200 dark:border-gray-700 px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-800 transition"
      >
        {/* Avatar */}
        <div class="flex h-9 w-9 items-center justify-center rounded-full bg-[#1F6F50] text-white font-semibold text-sm">
          {user.username.charAt(0).toUpperCase()}
        </div>

        {/* Username */}
        <div class="hidden md:flex flex-col items-start leading-tight">
          <span class="text-sm font-semibold text-gray-800 dark:text-gray-100">
            {user.username}
          </span>
          <span class="text-xs text-gray-500">
            Student
          </span>
        </div>

        {/* Arrow */}
        <svg
          id="menu-arrow"
          class="h-4 w-4 text-gray-500 transition-transform duration-200"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 9l-7 7-7-7"
          />
        </svg>
      </button>

      {/* Dropdown */}
      <div
        id="user-dropdown"
        class="hidden absolute right-0 mt-3 w-72 rounded-xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 shadow-2xl overflow-hidden z-50"
      >
        {/* Header */}
        <div class="px-5 py-4 bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[#1F6F50] text-white text-lg font-bold">
              {user.username.charAt(0).toUpperCase()}
            </div>

            <div>
              <h3 class="font-semibold text-gray-800 dark:text-white">
                {user.username}
              </h3>

              <p class="text-sm text-gray-500 truncate">
                {user.email}
              </p>
            </div>
          </div>
        </div>

        {/* Menu */}
        <nav class="py-2">

          <a
            href="/dashboard"
            class="flex items-center gap-3 px-5 py-3 hover:bg-gray-100 dark:hover:bg-gray-800 transition"
          >
            📊
            <span>Dashboard</span>
          </a>


        </nav>

        <div class="border-t border-gray-200 dark:border-gray-700">

          <button
            class="logout-btn flex w-full items-center gap-3 px-5 py-3 text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition"
          >
            🚪
            <span>Log out</span>
          </button>

        </div>
      </div>
    </div>
  ) : (
    <div class="flex items-center gap-3">

      <a
        href="/login"
        class="text-sm font-bold text-[#14171A] dark:text-gray-200 hover:text-[#1F6F50] dark:hover:text-green-400"
      >
        Log in
      </a>

      <a
        href="/signup"
        class="rounded-md bg-[#F0A93B] px-4 py-2 text-sm font-bold text-[#14171A] hover:bg-[#dd9a30] transition"
      >
        Sign Up
      </a>

    </div>
  )
}
<script>
  function initUserMenu() {
    const button = document.getElementById("user-menu-btn") as HTMLButtonElement | null;
    const dropdown = document.getElementById("user-dropdown") as HTMLDivElement | null;
    const arrow = document.getElementById("menu-arrow") as HTMLElement | null;

    if (button && dropdown && arrow) {
      button.addEventListener("click", (e) => {
        e.stopPropagation();
        dropdown.classList.toggle("hidden");
        arrow.classList.toggle("rotate-180");
      });

      document.addEventListener("click", () => {
        dropdown.classList.add("hidden");
        arrow.classList.remove("rotate-180");
      });

      dropdown.addEventListener("click", (e) => {
        e.stopPropagation();
      });
    }

    document
      .querySelectorAll<HTMLButtonElement>(".logout-btn")
      .forEach((btn) => {
        btn.addEventListener("click", async () => {
          try {
            await fetch("/api/auth/logout", {
              method: "POST",
            });
          } finally {
            window.location.href = "/";
          }
        });
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initUserMenu);
  } else {
    initUserMenu();
  }

  document.addEventListener("astro:after-swap", initUserMenu);
</script>