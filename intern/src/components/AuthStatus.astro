---
// src/components/AuthStatus.astro
// Rendered twice in Header.astro (desktop nav + mobile menu), so we use a
// CLASS here, not an id — duplicate ids on a page mean
// document.getElementById only ever finds the first one, silently leaving
// the second button's click listener never attached.
import { getCurrentUser } from "../types/auth-server";

const user = await getCurrentUser(Astro.cookies);
---

{
  user ? (
    <div class="flex items-center gap-4">
      <span class="text-sm text-gray-600">Hi, {user.username}</span>
      <button
        class="logout-btn text-sm font-bold text-[#1F6F50] hover:underline"
      >
        Log out
      </button>
    </div>
  ) : (
    <div class="flex items-center gap-3">
      <a
        href="/login"
        class="text-sm font-bold text-[#14171A] hover:text-[#1F6F50]"
      >
        Log in
      </a>
      <a
        href="/signup"
        class="text-sm font-bold px-4 py-2 bg-[#F0A93B] hover:bg-[#dd9a30] text-[#14171A] rounded-md"
      >
        Sign Up
      </a>
    </div>
  )
}

<script>
  // Attaches to EVERY .logout-btn on the page (desktop + mobile), not just
  // the first one — fixes the duplicate-id bug where only one button ever
  // worked depending on DOM order.
  function setupLogoutButtons() {
    document.querySelectorAll(".logout-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        await fetch("/api/auth/logout", { method: "POST" });
        window.location.href = "/";
      });
    });
  }

  setupLogoutButtons();
  document.addEventListener("astro:after-swap", setupLogoutButtons);
</script>