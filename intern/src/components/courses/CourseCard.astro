---
// src/components/courses/CourseCard.astro
import type { TCourse } from "../../types/course";

type Props = { course: TCourse };

const { course } = Astro.props;
const isPopular = course.isPopular;
---

<div
  class={`highlight-card relative rounded-2xl border p-8 flex flex-col ${
    isPopular
      ? "bg-gray-900 border-gray-900 dark:bg-gray-950 dark:border-gray-950 shadow-xl md:-translate-y-4"
      : "bg-white dark:bg-gray-700 border-gray-200 dark:border-gray-600"
  }`}
>
  {
    isPopular && (
      <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-orange-400 text-gray-900 text-xs font-bold px-4 py-1.5 rounded-full">
        MOST POPULAR
      </span>
    )
  }

  {
    course.category && (
      <span
        class={`inline-block self-start text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full mb-3 ${
          isPopular
            ? "bg-white/15 text-white border border-white/25"
            : "bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"
        }`}
      >
        {course.category.name}
      </span>
    )
  }

  <h3
    class={`text-lg font-black uppercase tracking-wide mb-2 ${
      isPopular ? "text-white" : "text-gray-900 dark:text-white"
    }`}
  >
    {course.title}
  </h3>
  <p
    class={`text-sm italic mb-6 ${
      isPopular ? "text-gray-300" : "text-gray-500 dark:text-gray-300"
    }`}
  >
    {course.description}
  </p>

  {
    course.instructor && (
      <p class={`text-xs mb-6 -mt-4 ${isPopular ? "text-gray-400" : "text-gray-400 dark:text-gray-500"}`}>
        Taught by <span class="font-semibold">{course.instructor.name}</span>
      </p>
    )
  }

  <div
    class={`rounded-xl px-6 py-5 mb-6 text-center ${
      isPopular ? "bg-gray-800" : "bg-gray-50 dark:bg-gray-800"
    }`}
  >
    <span
      class={`align-top text-sm font-bold mr-1 ${
        isPopular ? "text-orange-400" : "text-gray-900 dark:text-white"
      }`}
    >
      Rs
    </span>
    <span
      class={`text-4xl font-black ${
        isPopular ? "text-orange-400" : "text-gray-900 dark:text-white"
      }`}
    >
      {course.price}
    </span>
    <span
      class={`text-sm font-bold ${
        isPopular ? "text-orange-400" : "text-gray-900 dark:text-white"
      }`}
    >
      .00
    </span>
    <p
      class={`text-xs tracking-wide mt-1 ${
        isPopular ? "text-gray-400" : "text-gray-500 dark:text-gray-400"
      }`}
    >
      PER COURSE
    </p>
  </div>

  <div class={`space-y-3 mb-8 text-sm ${isPopular ? "text-gray-300" : "text-gray-600 dark:text-gray-300"}`}>
    <div
      class={`flex justify-between pb-3 border-b border-dashed ${
        isPopular ? "border-gray-700" : "border-gray-200 dark:border-gray-600"
      }`}
    >
      <span>Theory Lessons</span>
      <span class={`font-bold ${isPopular ? "text-white" : "text-gray-900 dark:text-white"}`}>
        {course.theoryLessons} Lessons
      </span>
    </div>
    <div
      class={`flex justify-between pb-3 border-b border-dashed ${
        isPopular ? "border-gray-700" : "border-gray-200 dark:border-gray-600"
      }`}
    >
      <span>Practical Lessons</span>
      <span class={`font-bold ${isPopular ? "text-white" : "text-gray-900 dark:text-white"}`}>
        {course.practicalLessons} Lessons
      </span>
    </div>
    <div class="flex justify-between">
      <span>Duration</span>
      <span class={`font-bold ${isPopular ? "text-white" : "text-gray-900 dark:text-white"}`}>
        {course.duration}
      </span>
    </div>
  </div>

  
  <a    href={`/courses/${course.slug}`}
    class={`mt-auto text-center py-3 rounded-xl font-bold transition ${
      isPopular
        ? "bg-orange-400 hover:bg-orange-500 text-gray-900"
        : "bg-gray-900 hover:bg-gray-800 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 text-white"
    }`}
  >
    BOOK NOW
  </a>
</div>

<style>
  .highlight-card {
    transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  }

  .highlight-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 0 2px rgba(255, 159, 28, 0.5), 0 8px 20px rgba(0, 0, 0, 0.15);
  }
</style>
