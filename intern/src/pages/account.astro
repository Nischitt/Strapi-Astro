---
// src/pages/account.astro
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import { getCurrentUser } from "../types/auth-server";

const user = await getCurrentUser(Astro.cookies);

if (!user) {
  return Astro.redirect("/login");
}
---

<Layout>
  <section class="max-w-3xl mx-auto px-6 py-20">
    <h1 class="font-display text-3xl font-bold uppercase text-[#14171A] mb-4">
      Welcome back, {user.username}
    </h1>
    <p class="text-gray-600">
      This is a members-only page — only people with a valid session can see
      it. Anyone without one gets redirected to /login automatically.
    </p>
  </section>
</Layout>