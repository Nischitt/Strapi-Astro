---
// src/pages/signup.astro
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="max-w-md mx-auto px-6 py-20">
    <h1 class="font-display text-3xl font-bold uppercase text-[#14171A] mb-8 text-center">
      Create Account
    </h1>

    <form id="signup-form" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Username
        </label>
        <input
          name="username"
          type="text"
          required
          class="w-full px-4 py-3 rounded-md border border-[#14171A]/15 focus:outline-none focus:ring-2 focus:ring-[#1F6F50]"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Email
        </label>
        <input
          name="email"
          type="email"
          required
          class="w-full px-4 py-3 rounded-md border border-[#14171A]/15 focus:outline-none focus:ring-2 focus:ring-[#1F6F50]"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Password
        </label>
        <input
          name="password"
          type="password"
          required
          minlength="6"
          class="w-full px-4 py-3 rounded-md border border-[#14171A]/15 focus:outline-none focus:ring-2 focus:ring-[#1F6F50]"
        />
      </div>

      <p id="signup-error" class="text-sm text-red-600 hidden"></p>

      <button
        type="submit"
        class="w-full py-3.5 bg-[#F0A93B] hover:bg-[#dd9a30] text-[#14171A] font-bold uppercase tracking-wide text-sm rounded-md transition"
      >
        Sign Up
      </button>
    </form>

    <p class="text-sm text-gray-500 text-center mt-6">
      Already have an account?
      <a id="login-link" href="/login" class="text-[#1F6F50] font-bold">Log in</a>
    </p>
  </section>
</Layout>

<script>
  import { registerUser } from "../types/auth-client";

  const form = document.getElementById("signup-form") as HTMLFormElement;
  const errorEl = document.getElementById("signup-error")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.classList.add("hidden");

    const formData = new FormData(form);
    const username = formData.get("username") as string;
    const email = formData.get("email") as string;
    const password = formData.get("password") as string;

    try {
      await registerUser(username, email, password);
      // Cookie is already set by the server response — navigate back to
      // wherever the user was trying to go (e.g. /contact), or home.
      const params = new URLSearchParams(window.location.search);
      const redirectTo = params.get("redirect") || "/";
      window.location.href = redirectTo;
    } catch (err) {
      errorEl.textContent =
        err instanceof Error ? err.message : "Something went wrong";
      errorEl.classList.remove("hidden");
    }
  });
</script>

<script>
  // Preserve ?redirect= when hopping over to the login page too.
  const params = new URLSearchParams(window.location.search);
  const redirectParam = params.get("redirect");
  if (redirectParam) {
    const loginLink = document.getElementById("login-link") as HTMLAnchorElement;
    loginLink.href = `/login?redirect=${encodeURIComponent(redirectParam)}`;
  }
</script>