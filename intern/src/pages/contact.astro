---
// src/pages/contact.astro
import Layout from "../layouts/Layout.astro";
import { getCurrentUser } from "../types/auth-server";

const user = await getCurrentUser(Astro.cookies);

if (!user) {
  return Astro.redirect("/login?redirect=/contact");
}
---

<Layout>
  <section class="max-w-2xl mx-auto px-6 py-20">
    <div class="text-center mb-12">
      <h1 class="font-display text-4xl font-bold uppercase text-[#14171A] dark:text-white mb-3">
        Get In Touch
      </h1>
      <p class="text-gray-500 dark:text-gray-400">
        Questions about a course? Send us a message and we'll get back to
        you shortly.
      </p>
    </div>

    <form id="contact-form" class="space-y-4">
      <!-- Honeypot field: hidden from real users via CSS, bots fill it anyway -->
      <input
        type="text"
        name="company"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        class="hidden"
      />

      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
          Name
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          value={user?.username ?? ""}
          readonly={!!user}
          aria-describedby={user ? "name-hint" : undefined}
          class={`w-full px-4 py-3 rounded-md border border-[#14171A]/15 dark:border-gray-500 dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#1F6F50] ${
            user ? "bg-gray-50 dark:bg-gray-600 text-gray-500 dark:text-gray-300 cursor-not-allowed" : ""
          }`}
        />
        {
          user && (
            <p id="name-hint" class="text-xs text-gray-400 dark:text-gray-500 mt-1">
              Filled in from your account
            </p>
          )
        }
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
          Email
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          value={user?.email ?? ""}
          readonly={!!user}
          aria-describedby={user ? "email-hint" : undefined}
          class={`w-full px-4 py-3 rounded-md border border-[#14171A]/15 dark:border-gray-500 dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#1F6F50] ${
            user ? "bg-gray-50 dark:bg-gray-600 text-gray-500 dark:text-gray-300 cursor-not-allowed" : ""
          }`}
        />
        {
          user && (
            <p id="email-hint" class="text-xs text-gray-400 dark:text-gray-500 mt-1">
              Filled in from your account
            </p>
          )
        }
      </div>

      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
          Phone <span class="text-gray-400 dark:text-gray-500">(optional)</span>
        </label>
        <input
          id="phone"
          name="phone"
          type="tel"
          class="w-full px-4 py-3 rounded-md border border-[#14171A]/15 dark:border-gray-500 dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#1F6F50]"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          aria-describedby="contact-error"
          class="w-full px-4 py-3 rounded-md border border-[#14171A]/15 dark:border-gray-500 dark:bg-gray-700 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#1F6F50]"
        ></textarea>
      </div>

      <p id="contact-error" class="text-sm text-red-600 hidden" role="alert" aria-live="assertive"></p>
      <p id="contact-success" class="text-sm text-[#1F6F50] dark:text-green-400 font-medium hidden" role="status" aria-live="polite">
        Thanks! Your message has been sent — we'll be in touch soon.
      </p>

      <button
        type="submit"
        id="contact-submit"
        class="w-full py-3.5 bg-[#F0A93B] hover:bg-[#dd9a30] text-[#14171A] font-bold uppercase tracking-wide text-sm rounded-md transition disabled:opacity-50 flex items-center justify-center gap-2"
      >
        <svg
          id="contact-spinner"
          class="hidden animate-spin h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
        </svg>
        <span>Send Message</span>
      </button>
    </form>
  </section>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const errorEl = document.getElementById("contact-error")!;
  const successEl = document.getElementById("contact-success")!;
  const submitBtn = document.getElementById(
    "contact-submit"
  ) as HTMLButtonElement;
  const spinner = document.getElementById("contact-spinner")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.classList.add("hidden");
    successEl.classList.add("hidden");
    submitBtn.disabled = true;
    spinner.classList.remove("hidden");

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (!res.ok) {
        throw new Error(data?.error || "Something went wrong.");
      }

      form.reset();
      form.classList.add("hidden");
      successEl.classList.remove("hidden");
    } catch (err) {
      errorEl.textContent =
        err instanceof Error ? err.message : "Something went wrong.";
      errorEl.classList.remove("hidden");
      submitBtn.disabled = false;
      spinner.classList.add("hidden");
    }
  });
</script>