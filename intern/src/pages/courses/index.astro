---
// src/pages/courses/index.astro
import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/courses/CourseCard.astro";
import { getCourses } from "../../types/loader";

const response = await getCourses();
const courses = response?.data ?? [];
---

<Layout>
  <section class="max-w-7xl mx-auto px-6 py-20">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h1 class="text-4xl font-black text-gray-900 mb-3">
        Valuable Packages &amp; Offers
      </h1>
      <p class="text-gray-500">
        Choose the perfect driving course tailored to your schedule, budget,
        and experience level.
      </p>
    </div>

    {
      courses.length === 0 ? (
        <p class="text-center text-gray-500">No courses published yet.</p>
      ) : (
        <div class="grid md:grid-cols-3 gap-8 items-start">
          {courses.map((course) => (
            <CourseCard course={course} />
          ))}
        </div>
      )
    }
  </section>
</Layout>