---
import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/courses/CourseCard.astro";
import { getCourses } from "../../types/loader";

const response = await getCourses();
const courses = response?.data ?? [];
---

<Layout>
<section class="bg-gray-50 border-t border-gray-200">

    <div class="max-w-7xl mx-auto px-6 py-14">

        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-10">

            <div class="max-w-xl">

                <p class="text-sm font-semibold uppercase tracking-widest text-blue-600">
                    Courses
                </p>

                <h1 class="mt-2 text-3xl font-bold text-gray-900">
                    Driving Courses & Packages
                </h1>

                <p class="mt-4 text-gray-600 leading-7">
                    Whether you're learning to drive for the first time or preparing
                    for your licence test, choose a package that matches your goals.
                </p>

            </div>

            <div class="flex gap-10">

                <div>
                    <h3 class="text-2xl font-bold text-gray-900">
                        {courses.length}+
                    </h3>
                    <p class="text-sm text-gray-500">
                        Available Courses
                    </p>
                </div>

                <div>
                    <h3 class="text-2xl font-bold text-gray-900">
                        Flexible
                    </h3>
                    <p class="text-sm text-gray-500">
                        Scheduling
                    </p>
                </div>

            </div>

        </div>

        {
            courses.length === 0
            ? (
                <div class="rounded-xl border bg-white py-20 text-center">
                    <p class="text-gray-500">
                        Courses will appear here soon.
                    </p>
                </div>
            )
            : (
                <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                    {courses.map(course => (
                        <CourseCard course={course}/>
                    ))}
                </div>
            )
        }

    </div>

</section>
</Layout>