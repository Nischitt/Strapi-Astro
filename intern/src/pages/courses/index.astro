---
import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/courses/CourseCard.astro";
import { getCourses, getCategories } from "../../types/loader";

// Filtering happens server-side via the ?category= query param (a
// category's slug, e.g. "two-wheeler") — no client-side fetch, no state
// to keep in sync, works with JS off, and each filtered view is its own
// shareable/bookmarkable URL. Categories themselves are fetched live
// from Strapi, so adding/renaming/removing one in the admin panel shows
// up here immediately with no code change.
const categoriesResponse = await getCategories();
const categories = categoriesResponse?.data ?? [];

const activeSlug = Astro.url.searchParams.get("category") || undefined;
// Guard against a stale/bad ?category= value in the URL (e.g. someone
// edited it by hand, or a category was deleted) — fall back to "All".
const activeCategory = categories.find((c) => c.slug === activeSlug);
const effectiveSlug = activeCategory?.slug;

const response = await getCourses(effectiveSlug);
const courses = response?.data ?? [];

const activeLabel = activeCategory?.name ?? "All Courses";

function hrefFor(slug?: string) {
  return slug ? `/courses?category=${slug}` : "/courses";
}
---

<Layout>
<section class="bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-600">

    <div class="max-w-7xl mx-auto px-6 py-14">

        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-10">

            <div class="max-w-xl">

                <p class="text-sm font-semibold uppercase tracking-widest text-blue-600">
                    Courses
                </p>

                <h1 class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">
                    Driving Courses & Packages
                </h1>

                <p class="mt-4 text-gray-600 dark:text-gray-300 leading-7">
                    Whether you're learning to drive for the first time or preparing
                    for your licence test, choose a package that matches your goals.
                </p>

            </div>

            <div class="flex gap-10">

                <div>
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
                        {courses.length}+
                    </h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        Available Courses
                    </p>
                </div>

                <div>
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
                        Flexible
                    </h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        Scheduling
                    </p>
                </div>

            </div>

        </div>

        <!-- Category filter popup -->
        {
          categories.length > 0 && (
            <div class="relative inline-block mb-8" id="category-filter">
                <button
                    id="category-filter-button"
                    type="button"
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-controls="category-filter-menu"
                    class="flex items-center gap-2 px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm font-semibold text-gray-800 dark:text-gray-100 hover:border-gray-400 dark:hover:border-gray-500 transition"
                >
                    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h18M6 9h12M9 14h6M11 19h2" />
                    </svg>
                    <span>{activeLabel}</span>
                    <svg class="w-4 h-4 text-gray-400 transition-transform" id="category-filter-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>

                <div
                    id="category-filter-menu"
                    role="menu"
                    aria-labelledby="category-filter-button"
                    class="hidden absolute left-0 mt-2 w-56 rounded-lg border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 shadow-lg z-20 py-1 max-h-80 overflow-y-auto"
                >
                    <a
                        href={hrefFor(undefined)}
                        role="menuitem"
                        class={`flex items-center justify-between px-4 py-2.5 text-sm font-medium transition ${
                            !effectiveSlug
                                ? "text-[#1F6F50] dark:text-green-400 bg-green-50 dark:bg-green-900/30"
                                : "text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600"
                        }`}
                    >
                        All Courses
                        {!effectiveSlug && (
                            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                            </svg>
                        )}
                    </a>

                    {categories.map((cat) => (
                        <a
                            href={hrefFor(cat.slug)}
                            role="menuitem"
                            class={`flex items-center justify-between px-4 py-2.5 text-sm font-medium transition ${
                                effectiveSlug === cat.slug
                                    ? "text-[#1F6F50] dark:text-green-400 bg-green-50 dark:bg-green-900/30"
                                    : "text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600"
                            }`}
                        >
                            {cat.name}
                            {effectiveSlug === cat.slug && (
                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                </svg>
                            )}
                        </a>
                    ))}
                </div>
            </div>
          )
        }

        {
            courses.length === 0
            ? (
                <div class="rounded-xl border dark:border-gray-600 bg-white dark:bg-gray-700 py-20 text-center">
                    <p class="text-gray-500 dark:text-gray-400">
                        {effectiveSlug
                            ? `No ${activeLabel.toLowerCase()} courses available yet.`
                            : "Courses will appear here soon."}
                    </p>
                </div>
            )
            : (
                <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                    {courses.map(course => (
                        <CourseCard course={course}/>
                    ))}
                </div>
            )
        }

    </div>

</section>
</Layout>

<script>
  function setupCategoryFilter() {
    const wrapper = document.getElementById("category-filter");
    const button = document.getElementById("category-filter-button");
    const menu = document.getElementById("category-filter-menu");
    const chevron = document.getElementById("category-filter-chevron");
    if (!wrapper || !button || !menu) return;

    const open = () => {
      menu.classList.remove("hidden");
      button.setAttribute("aria-expanded", "true");
      chevron?.classList.add("rotate-180");
      document.addEventListener("click", onClickOutside);
      document.addEventListener("keydown", onKeydown);
    };

    const close = () => {
      menu.classList.add("hidden");
      button.setAttribute("aria-expanded", "false");
      chevron?.classList.remove("rotate-180");
      document.removeEventListener("click", onClickOutside);
      document.removeEventListener("keydown", onKeydown);
    };

    const onClickOutside = (e: MouseEvent) => {
      if (!wrapper.contains(e.target as Node)) close();
    };

    const onKeydown = (e: KeyboardEvent) => {
      if (e.key === "Escape") {
        close();
        (button as HTMLElement).focus();
      }
    };

    button.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";
      isOpen ? close() : open();
    });
  }

  setupCategoryFilter();
  document.addEventListener("astro:after-swap", setupCategoryFilter);
</script>