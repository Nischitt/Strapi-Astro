---
// src/pages/blog/[slug].astro
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import StrapiImage from "../../components/StrapiImage.astro";
import { getArticleBySlug } from "../../types/loader";

const { slug } = Astro.params;
const response = await getArticleBySlug(slug as string);
const article = response?.data?.[0];

if (!article) {
  return Astro.redirect("/404");
}
---

<Layout>
  <article class="max-w-3xl mx-auto px-6 py-16">
    <!-- Breadcrumb Navigation -->
    <nav class="text-sm text-gray-600 dark:text-gray-400 flex items-center gap-2 mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-emerald-600 dark:hover:text-white transition">Home</a>
      <span class="text-gray-400 dark:text-gray-600">/</span>
      <a href="/blog" class="hover:text-emerald-600 dark:hover:text-white transition">Blog</a>
      <span class="text-gray-400 dark:text-gray-600">/</span>
      <span class="text-gray-900 dark:text-gray-200 font-medium truncate">{article.title}</span>
    </nav>

    {
      article.featuredImage?.url && (
        <StrapiImage
          src={article.featuredImage.url}
          alt={article.featuredImage.alternativeText || article.title}
          width={800}
          height={450}
          class="w-full h-auto rounded-2xl object-cover mb-8"
        />
      )
    }

    <h1 class="text-4xl font-black text-gray-900 dark:text-white mb-3">{article.title}</h1>

    <div class="flex items-center gap-3 mb-8 text-sm text-gray-600 dark:text-gray-400">
      {article.author?.fullName && <span>By {article.author.fullName}</span>}
      {article.contentTags?.length > 0 && (
        <div class="flex gap-2">
          {article.contentTags.map((tag) => (
            <span class="bg-emerald-100 dark:bg-emerald-500/20 text-emerald-800 dark:text-emerald-300 px-2.5 py-0.5 rounded-full border border-emerald-200 dark:border-emerald-500/30">
              {tag.title}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Article Content: text-gray-800 in Light Mode, dark:text-gray-200 in Dark Mode -->
    <div class="prose dark:prose-invert max-w-none whitespace-pre-line text-gray-800 dark:text-gray-200 leading-relaxed">
      {article.content}
    </div>
  </article>
</Layout>