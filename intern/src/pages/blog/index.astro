---
// src/pages/blog/index.astro
import Layout from "../../layouts/Layout.astro";
import ArticleCard from "../../components/blog/ArticleCard.astro";
import { getArticles } from "../../types/loader";

Astro.response.headers.set("Cache-Control", "no-store");

const response = await getArticles();
const articles = response?.data ?? [];
---

<Layout>
  <section class="max-w-7xl mx-auto px-6 py-16">
    <p class="text-sm font-semibold uppercase tracking-widest text-[#F0A93B] mb-2">
      Blogs
    </p>
    
    <!-- Updated to text-white for guaranteed high contrast -->
    <h1 class="text-4xl font-black text-white mb-10">
      Blogs
    </h1>

    {
      articles.length === 0 ? (
        <p class="text-gray-400">No articles published yet.</p>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      )
    }
  </section>
</Layout>