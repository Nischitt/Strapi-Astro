---
// src/components/blocks/Newsletter.astro
import type { TNewsletterBlock } from "../../types/landing";

type Props = TNewsletterBlock;

const { heading, text, placeholder, label } = Astro.props;
---

<section class="max-w-2xl mx-auto px-6 py-16 text-center border-t border-neutral-200 dark:border-gray-600">
  <h2 class="text-2xl md:text-3xl font-medium text-neutral-900 dark:text-white mb-2">
    {heading}
  </h2>
  <p class="text-neutral-600 dark:text-gray-300 mb-6">{text}</p>
  <form class="flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto">
    <input
      type="email"
      placeholder={placeholder}
      class="flex-1 px-4 py-2.5 rounded border border-neutral-300 dark:border-gray-500 dark:bg-gray-700 dark:text-white dark:placeholder:text-gray-400 focus:outline-none focus:border-neutral-500"
    />
    <button
      type="submit"
      class="px-5 py-2.5 bg-neutral-900 hover:bg-neutral-700 dark:bg-white dark:text-neutral-900 dark:hover:bg-gray-200 text-white text-sm rounded transition"
    >
      {label}
    </button>
  </form>
</section>