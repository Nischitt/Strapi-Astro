---
// src/components/blocks/Markdown.astro
import { marked } from "marked";
import type { TMarkdownBlock } from "../../types/landing";

type Props = TMarkdownBlock;

const { content } = Astro.props;
const html = content ? marked.parse(content) : "";
---

<section class="max-w-2xl mx-auto px-6 py-14 prose prose-neutral dark:prose-invert prose-headings:font-medium prose-a:text-neutral-900 dark:prose-a:text-white prose-a:underline">
  <Fragment set:html={html} />
</section>