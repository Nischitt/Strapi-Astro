---
// src/components/blocks/SectionHeading.astro
import type { TSectionHeadingBlock } from "../../types/landing";

type Props = TSectionHeadingBlock;

const { subHeading, heading, anchorLink } = Astro.props;
---

<section
  id={anchorLink || undefined}
  class="max-w-3xl mx-auto px-6 py-14 text-center"
>
  {
    subHeading && (
      <p class="text-sm font-medium text-neutral-500 dark:text-gray-400 mb-2">{subHeading}</p>
    )
  }
  <h2 class="text-2xl md:text-3xl font-medium text-neutral-900 dark:text-white">
    {heading}
  </h2>
</section>