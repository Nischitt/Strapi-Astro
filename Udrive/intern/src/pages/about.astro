---
// src/pages/about.astro
import Layout from "../layouts/Layout.astro";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";
import LaneDivider from "../components/blocks/LaneDivider.astro";
import StrapiImage from "../components/StrapiImage.astro";
import { getPageBySlug } from "../types/loader";
import type { THeroBlock } from "../types/landing";

const response = await getPageBySlug("about");
const page = response?.data?.[0];
const allBlocks = page?.blocks ?? [];

// Pull the hero block's content/image for the custom header below,
// instead of rendering it through the same Hero component the landing
// page uses — keeps About visually distinct while still letting you
// edit the heading/text/image from Strapi like normal.
const heroBlock = allBlocks.find(
  (b) => b.__component === "blocks.hero"
) as THeroBlock | undefined;

// Everything else renders normally through BlockRenderer.
const remainingBlocks = allBlocks.filter(
  (b) => b.__component !== "blocks.hero"
);
---

<Layout>
  <!-- Custom About header -->
  <section class="max-w-7xl mx-auto px-6 pt-20 pb-16 grid md:grid-cols-[1.1fr_0.9fr] gap-12 items-center">
    <div>
      <p class="font-display uppercase tracking-[0.2em] text-[#F0A93B] text-sm mb-4">
        {page?.title ?? "About"}
      </p>
      <h1 class="font-display text-4xl md:text-5xl font-bold uppercase leading-[1.1] text-[#14171A] dark:text-white mb-6">
        {heroBlock?.heading ?? page?.title}
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
        {heroBlock?.text ?? page?.Description}
      </p>
    </div>

    {
      heroBlock?.image?.url && (
        <div class="relative">
          <div class="absolute -inset-4 border-2 border-dashed border-[#F0A93B]/40 rounded-2xl -z-10" />
          <StrapiImage
            src={heroBlock.image.url}
            alt={heroBlock.image.alternativeText || heroBlock.heading}
            width={640}
            height={480}
            class="rounded-2xl w-full h-auto object-cover"
          />
        </div>
      )
    }
  </section>

  {
    remainingBlocks.map((block, i) => (
      <>
        <LaneDivider />
        <BlockRenderer block={block} />
      </>
    ))
  }
</Layout>