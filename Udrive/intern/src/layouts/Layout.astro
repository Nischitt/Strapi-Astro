---
import type { TBanner, THeader, TFooter } from "../types";
import "../styles/global.css";

import Banner from "../components/Banner.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCurrentUser } from "../types/auth-server";

type TStrapiResponse<T> = {
  success: boolean;
  data?: T;
  error?: {
    status: number;
    name: string;
    message: string;
    details?: Record<string, string[]>;
  };
  meta?: {
    pagination: {
      page: number;
      pageSize: number;
      pageCount: number;
      total: number;
    };
  };
};

type TGlobalData = {
	id: number;
	documentId: string;
	description: string;
	createdAt: string;
	publishedAt: string;
	banner: TBanner;
	header: THeader;
	footer: TFooter;
}

async function getStrapiGlobalData(): Promise<TStrapiResponse<TGlobalData>>{
	const BASE_API_URL = import.meta.env.VITE_STRAPI_BASE_URL ?? "http://localhost:1337";
	const path = "/api/global";
	const url = new URL(path, BASE_API_URL)
	const response = await fetch(url.href);
	const data = await response.json()
	return data;
}

// Previously: this fetch ran, THEN Header.astro ran its own separate
// getCurrentUser() fetch afterward — two sequential round-trips to
// Strapi, one after another. Promise.all runs them concurrently instead,
// so the total wait is however long the SLOWER of the two takes, not
// both added together.
const [globalData, user] = await Promise.all([
	getStrapiGlobalData(),
	getCurrentUser(Astro.cookies),
]);

const {banner, header, footer} = globalData.data ?? {};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		<script is:inline>
			// Runs before paint to avoid a flash of the wrong theme.
			const stored = localStorage.getItem('theme');
			const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			if (stored === 'dark' || (!stored && prefersDark)) {
				document.documentElement.classList.add('dark');
			}
		</script>
	</head>
<body class="bg-white dark:bg-gray-800 text-[#14171A] dark:text-gray-200 transition-colors">

		<div id="page-loader" class="fixed top-0 left-0 h-1 bg-[#4F8A63] w-0 opacity-0 z-[100] transition-all duration-300"></div>

		{
			banner && <Banner data = {banner} />
		}

		{
			header && <Header data = {header} user={user} />
		}

		<main>
			<slot />
		</main>

		{
			footer && <Footer data = {footer} />
		}

	</body>
</html>

<script>
	// This project uses standard multi-page navigation (no <ClientRouter />
	// / View Transitions), so astro:before-preparation and astro:page-load
	// never fire. Show the bar right before the browser unloads the page
	// for a new navigation — it disappears naturally once the new page
	// loads, since the bar starts at width 0 / opacity 0 on every fresh load.
	function showLoader() {
		const bar = document.getElementById('page-loader');
		if (bar) {
			bar.style.opacity = '1';
			bar.style.width = '80%';
		}
	}

	window.addEventListener('beforeunload', showLoader);

	// Covers the bfcache case (back/forward navigation restores the page
	// without a fresh load) — make sure the bar isn't left visible.
	window.addEventListener('pageshow', (e) => {
		const bar = document.getElementById('page-loader');
		if (bar && (e as PageTransitionEvent).persisted) {
			bar.style.opacity = '0';
			bar.style.width = '0';
		}
	});
</script>

