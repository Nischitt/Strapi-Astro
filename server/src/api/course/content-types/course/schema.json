{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "text"
    },
    "duration": {
      "type": "string"
    },
    "price": {
      "type": "decimal"
    },
    "content": {
      "type": "richtext"
    },
    "level": {
      "type": "enumeration",
      "enum": [
        "Beginner",
        "Intermediate",
        "Advance"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "courses"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "theoryLessons": {
      "type": "integer"
    },
    "practicalLessons": {
      "type": "integer"
    },
    "isPopular": {
      "type": "boolean",
      "default": false
    },
    "bookings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::booking.booking",
      "mappedBy": "course"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "course"
    },
    "instructor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::instructor.instructor",
      "inversedBy": "courses"
    },
    "discountPrice": {
      "type": "decimal"
    },
    "totalLessons": {
      "type": "integer"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "vehicleType": {
      "type": "enumeration",
      "enum": [
        "Manual",
        "Automatic",
        "Both"
      ]
    },
    "maximumStudents": {
      "type": "integer"
    },
    "bookingEnabled": {
      "type": "boolean",
      "default": true
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    },
    "availableSlots": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::available-slot.available-slot",
      "mappedBy": "course"
    }
  }
}