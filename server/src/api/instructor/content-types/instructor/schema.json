{
  "kind": "collectionType",
  "collectionName": "instructors",
  "info": {
    "singularName": "instructor",
    "pluralName": "instructors",
    "displayName": "Instructor"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "biography": {
      "type": "text"
    },
    "certifications": {
      "type": "text"
    },
    "yearsOfExperience": {
      "type": "integer"
    },
    "languagesSpoken": {
      "type": "string"
    },
    "vehicleSpecialization": {
      "type": "string"
    },
    "courses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::course.course",
      "mappedBy": "instructor"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "instructor"
    },
    "workingDays": {
      "type": "text"
    },
    "workingHoursStart": {
      "type": "time"
    },
    "workingHoursEnd": {
      "type": "time"
    },
    "available": {
      "type": "boolean",
      "default": true
    },
    "bookings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::booking.booking",
      "mappedBy": "instructor"
    },
    "vehicles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::vehicle.vehicle",
      "mappedBy": "instructor"
    }
  }
}