---
// src/pages/contact.astro
import Layout from "../layouts/Layout.astro";
import { getCurrentUser } from "../types/auth-server";

const user = await getCurrentUser(Astro.cookies);

if (!user) {
  return Astro.redirect("/login?redirect=/contact");
}
---

<Layout>
  <section class="max-w-2xl mx-auto px-6 py-20">
    <div class="text-center mb-12">
      <h1 class="font-display text-4xl font-bold uppercase text-[#14171A] mb-3">
        Get In Touch
      </h1>
      <p class="text-gray-500">
        Questions about a course? Send us a message and we'll get back to
        you shortly.
      </p>
    </div>

    <form id="contact-form" class="space-y-4">
      <!-- Honeypot field: hidden from real users via CSS, bots fill it anyway -->
      <input
        type="text"
        name="company"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
      />

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Name
        </label>
        <input
          name="name"
          type="text"
          required
          value={user?.username ?? ""}
          readonly={!!user}
          class={`w-full px-4 py-3 rounded-md border border-[#14171A]/15 focus:outline-none focus:ring-2 focus:ring-[#1F6F50] ${
            user ? "bg-gray-50 text-gray-500 cursor-not-allowed" : ""
          }`}
        />
        {
          user && (
            <p class="text-xs text-gray-400 mt-1">
              Filled in from your account
            </p>
          )
        }
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Email
        </label>
        <input
          name="email"
          type="email"
          required
          value={user?.email ?? ""}
          readonly={!!user}
          class={`w-full px-4 py-3 rounded-md border border-[#14171A]/15 focus:outline-none focus:ring-2 focus:ring-[#1F6F50] ${
            user ? "bg-gray-50 text-gray-500 cursor-not-allowed" : ""
          }`}
        />
        {
          user && (
            <p class="text-xs text-gray-400 mt-1">
              Filled in from your account
            </p>
          )
        }
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Phone <span class="text-gray-400">(optional)</span>
        </label>
        <input
          name="phone"
          type="tel"
          class="w-full px-4 py-3 rounded-md border border-[#14171A]/15 focus:outline-none focus:ring-2 focus:ring-[#1F6F50]"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Message
        </label>
        <textarea
          name="message"
          required
          rows="5"
          class="w-full px-4 py-3 rounded-md border border-[#14171A]/15 focus:outline-none focus:ring-2 focus:ring-[#1F6F50]"
        ></textarea>
      </div>

      <p id="contact-error" class="text-sm text-red-600 hidden"></p>
      <p id="contact-success" class="text-sm text-[#1F6F50] font-medium hidden">
        Thanks! Your message has been sent — we'll be in touch soon.
      </p>

      <button
        type="submit"
        id="contact-submit"
        class="w-full py-3.5 bg-[#F0A93B] hover:bg-[#dd9a30] text-[#14171A] font-bold uppercase tracking-wide text-sm rounded-md transition disabled:opacity-50"
      >
        Send Message
      </button>
    </form>
  </section>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const errorEl = document.getElementById("contact-error")!;
  const successEl = document.getElementById("contact-success")!;
  const submitBtn = document.getElementById(
    "contact-submit"
  ) as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.classList.add("hidden");
    successEl.classList.add("hidden");
    submitBtn.disabled = true;

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (!res.ok) {
        throw new Error(data?.error || "Something went wrong.");
      }

      form.reset();
      form.classList.add("hidden");
      successEl.classList.remove("hidden");
    } catch (err) {
      errorEl.textContent =
        err instanceof Error ? err.message : "Something went wrong.";
      errorEl.classList.remove("hidden");
      submitBtn.disabled = false;
    }
  });
</script>