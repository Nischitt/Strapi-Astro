---
// src/components/blocks/Hero.astro
import type { THeroBlock } from "../../types/landing";
import StrapiImage from "../StrapiImage.astro";

type Props = THeroBlock;

const { heading, text, links, image } = Astro.props;
---

<section class="relative bg-[#14171A] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 py-24 md:py-32 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="font-display uppercase tracking-[0.2em] text-[#F0A93B] text-sm mb-4">
        uDrive Driving School
      </p>
      <h1 class="font-display text-5xl md:text-6xl font-bold uppercase leading-[1.05] text-white mb-6">
        {heading}
      </h1>
      <p class="text-lg text-gray-300 max-w-xl mb-10">{text}</p>
      <div class="flex flex-wrap gap-4">
        {
          links?.map((link) => (
            <a
              href={link.href}
              target={link.isExternal ? "_blank" : "_self"}
              rel={link.isExternal ? "noopener noreferrer" : undefined}
              class={
                link.type === "PRIMARY"
                  ? "inline-flex items-center px-7 py-3.5 bg-[#F0A93B] hover:bg-[#dd9a30] text-[#14171A] font-bold uppercase tracking-wide text-sm rounded-md transition"
                  : "inline-flex items-center px-7 py-3.5 border-2 border-white/20 hover:border-white/40 text-white font-bold uppercase tracking-wide text-sm rounded-md transition"
              }
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    {
      image?.url && (
        <div class="relative rounded-2xl overflow-hidden">
          <StrapiImage
            src={image.url}
            alt={image.alternativeText || heading}
            width={640}
            height={480}
            class="w-full h-auto object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#14171A]/60 via-transparent to-transparent" />
        </div>
      )
    }
  </div>
</section>