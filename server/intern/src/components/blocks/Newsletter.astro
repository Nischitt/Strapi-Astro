---
// src/components/blocks/Newsletter.astro
import type { TNewsletterBlock } from "../../types/landing";

type Props = TNewsletterBlock;

const { heading, text, placeholder, label } = Astro.props;
---

<section class="max-w-3xl mx-auto px-6 py-20 text-center">
  <h2 class="font-display text-3xl md:text-4xl font-bold uppercase text-[#14171A] mb-2">
    {heading}
  </h2>
  <p class="text-gray-600 mb-8">{text}</p>
  <form class="flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto">
    <input
      type="email"
      placeholder={placeholder}
      class="flex-1 px-4 py-3.5 rounded-md border border-[#14171A]/15 focus:outline-none focus:ring-2 focus:ring-[#1F6F50]"
    />
    <button
      type="submit"
      class="px-7 py-3.5 bg-[#F0A93B] hover:bg-[#dd9a30] text-[#14171A] font-bold uppercase tracking-wide text-sm rounded-md transition"
    >
      {label}
    </button>
  </form>
</section>